{
  "name": "protlin-language-support",
  "displayName": "Protlin Language Support",
  "description": "Language support for Protlin programming language",
  "version": "1.0.0",
  "publisher": "moude-ai",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "protlin",
    "programming",
    "language",
    "protein",
    "egg"
  ],
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Arthurc1Moude/Protlin.git"
  },
  "contributes": {
    "languages": [
      {
        "id": "protlin",
        "aliases": [
          "Protlin",
          "protlin"
        ],
        "extensions": [
          ".prot"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "protlin",
        "scopeName": "source.protlin",
        "path": "./syntaxes/protlin.tmLanguage.json"
      }
    ]
  },
  "devDependencies": {
    "@vscode/vsce": "^2.15.0"
  }
}